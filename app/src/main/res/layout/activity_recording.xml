<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream_bg">

    <!-- Status bar -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/cream_card"
        android:gravity="center"
        android:background="@color/navy_deep"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"/>

    <!-- Scrollable transcript feed -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFeed"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="8dp"/>

    <!-- ── Bottom control panel ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/cream_card"
        android:elevation="8dp"
        android:padding="16dp">

        <!-- Countdown timer — large and central -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1:00"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="@color/navy_deep"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:fontFamily="monospace"/>

        <!-- Big record / stop button -->
        <Button
            android:id="@+id/btnRecord"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="⏺  Record"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/navy_deep"
            android:backgroundTint="@color/gold_primary"
            android:layout_marginBottom="10dp"
            style="@style/Widget.MaterialComponents.Button"/>

        <!-- Utility row: Export + Clear -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Export"
                android:textColor="@color/cream_card"
                android:backgroundTint="@color/navy_deep"
                style="@style/Widget.MaterialComponents.Button"/>

            <Button
                android:id="@+id/btnClear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Clear History"
                style="@style/App.Button.Outline"/>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
