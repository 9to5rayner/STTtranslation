<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/cream_bg"
    android:padding="32dp">

    <ImageView
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:src="@drawable/ic_launcher_foreground"
        android:background="@color/navy_deep"
        android:padding="14dp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BizCommunicator"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/navy_deep"
        android:letterSpacing="0.02"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvAuthTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:letterSpacing="0.04"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnGoogleSignIn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Sign in with Google"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/navy_deep"
        android:textAllCaps="false"
        android:backgroundTint="@color/gold_primary"
        android:drawablePadding="12dp"
        android:gravity="center"
        style="@style/Widget.MaterialComponents.Button"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your Google account is used to identify you in the chat — no separate password needed."
        android:textSize="12sp"
        android:textColor="@color/text_hint"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginTop="20dp"/>

</LinearLayout>
