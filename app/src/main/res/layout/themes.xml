<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GroqTranscriber" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/navy_deep</item>
        <item name="colorPrimaryDark">@color/navy_deep</item>
        <item name="colorAccent">@color/gold_primary</item>
        <item name="android:windowBackground">@color/cream_bg</item>
        <item name="android:statusBarColor">@color/navy_deep</item>
        <item name="android:navigationBarColor">@color/navy_deep</item>

        <!-- Card style -->
        <item name="materialCardViewStyle">@style/App.CardView</item>

        <!-- Button style -->
        <item name="materialButtonStyle">@style/App.Button</item>
    </style>

    <style name="App.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/cream_card</item>
    </style>

    <style name="App.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/navy_deep</item>
        <item name="android:textColor">@color/cream_card</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="App.Button.Gold" parent="App.Button">
        <item name="backgroundTint">@color/gold_primary</item>
        <item name="android:textColor">@color/navy_deep</item>
    </style>

    <style name="App.Button.Danger" parent="App.Button">
        <item name="backgroundTint">@color/recording_red</item>
        <item name="android:textColor">@color/cream_card</item>
    </style>

    <style name="App.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/navy_deep</item>
        <item name="android:textColor">@color/navy_deep</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <!-- Text styles -->
    <style name="App.Text.Header" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.Text.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>
</resources>
